APP_ENV=prod
PROJECT_NAME=CCK Mobilya API
ROOT_PATH=/api
DATABASE_URL=postgresql+psycopg2://db_user:db_password@your-rds-endpoint:5432/furniture
CORS_ORIGINS=["https://example.com","https://admin.example.com"]

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

STORAGE_BACKEND=s3
MEDIA_ROOT=media
MEDIA_URL_PREFIX=media
APP_BASE_URL=https://api.example.com

AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_BUCKET_NAME=example-media-bucket
S3_PUBLIC_BASE_URL=https://media.example.com
